# ─────────────────────────────────────────────────────────────
# Bookshelf — environment variables
# Copy this file to .env.local and fill in your values.
# ─────────────────────────────────────────────────────────────

# Clerk — get from https://clerk.com/dashboard
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs (leave as-is for local dev)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/library
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Convex — run `npx convex dev` to auto-generate this URL
# https://docs.convex.dev/quickstart/nextjs
NEXT_PUBLIC_CONVEX_URL=https://....convex.cloud

# Hardcover API — get from https://hardcover.app/account/api
# Used server-side for book cover lookups (optional — app works without it)
HARDCOVER_API_KEY=

# Public base URL — used for sitemap, canonical tags, and OG images
# Set to your production domain when deploying
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# Convex-side secrets (set via `npx convex env set KEY VALUE`)
# ─────────────────────────────────────────────────────────────
# HARDCOVER_KEY_SECRET=<32-byte hex string for AES-GCM encryption>
